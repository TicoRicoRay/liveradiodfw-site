# liveradiodfw-site -- local secrets and config.
# Copy this file to `.env` in the same directory and fill in real values.
# Never commit .env to the repo (see .gitignore).


# --- Cloudflare cache purge (purge_cache.py, R26) ---------------------------
# Scoped API token. Minimum permissions needed:
#   Zone > Cache Purge > Purge
# Optionally also:
#   Zone > DNS > Edit    (only if you expand the tool to manage DNS later)
#
# Zone resource must be restricted to `liveradiodfw.com` only.
#
# Where to get it:
#   https://dash.cloudflare.com/profile/api-tokens
#   Click "Create Token", pick "Custom token", scope as above.
#   The token value is shown ONCE at creation time. Save it in 1Password
#   under "LiveRadioDFW Cloudflare API token" immediately.
#
# If the 2026-04-21 token is lost, use "Roll" on the existing token row to
# generate a new value for the same scope (invalidates the old value).
CLOUDFLARE_API_TOKEN=REPLACE_WITH_TOKEN

# Zone ID for liveradiodfw.com. NOT secret, but required.
# Where to get it:
#   https://dash.cloudflare.com -> select liveradiodfw.com -> Overview page
#   -> right-hand sidebar -> "Zone ID" (32-character hex string).
CLOUDFLARE_ZONE_ID=REPLACE_WITH_ZONE_ID


# --- GitHub Pages branch override (B7 / B30) --------------------------------
# Legacy default in some scripts is still "gh-pages"; override to "master"
# on Ray's Windows box to match current deployment.
# GIT_BRANCH=master
